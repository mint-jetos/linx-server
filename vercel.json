{
  "version": 2,
  "builds": [
    {
      "src": ".",
      "use": "@vercel/go",
      "config": {
        "static": {
          "include": ["static"]
        },
        "templates": {
          "include": ["templates"]
        },
        "env": {
          "FILESPATH": "/data/files",
          "METAPATH": "/data/meta"
        },
        "port": 8080,
        "entrypoint": ["linx-server", "-bind=0.0.0.0:8080", "-filespath=/data/files/", "-metapath=/data/meta/"]
      },
      "build": "mkdir -p /data/files && mkdir -p /data/meta && chown -R 65534:65534 /data && go build -o linx-server ."
    }
  ]
}
